{
  "name": "Portfolio",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate && node -e \"require('fs').copyFileSync('.output/public/index.html','.output/public/404.html')\"",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prebuild": "node scripts/fetch-live-signal.mjs",
    "pregenerate": "node scripts/fetch-live-signal.mjs",
    "dev:setup": "node scripts/setup-dev.mjs",
    "typecheck": "nuxt typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run test:unit && npm run test:int && npm run test:e2e",
    "test:unit": "vitest run --dir tests/unit",
    "test:int": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=mobile --project=desktop",
    "test:e2e:ui": "playwright test --project=mobile --project=desktop --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:prod": "playwright test --project=production-smoke"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "nuxt": "^4.3.1",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@nuxt/content": "^3.11.2",
    "@nuxt/eslint": "^0.7.0",
    "@nuxt/fonts": "^0.13.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/test-utils": "^3.15.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@playwright/test": "^1.48.0",
    "@resvg/resvg-js": "^2.6.2",
    "@vitest/coverage-v8": "^3.2.0",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/nuxt": "^14.2.0",
    "eslint": "^9.13.0",
    "happy-dom": "^15.7.0",
    "playwright-core": "^1.48.0",
    "playwright-lighthouse": "^4.0.0",
    "vitest": "^3.2.0",
    "vue-tsc": "^2.1.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  }
}
